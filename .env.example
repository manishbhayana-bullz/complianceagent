# --- LLM provider (Gemini = free tier, no credit card needed) ---
GEMINI_API_KEY=your_gemini_api_key_here
# Model used for chat/completion + audit report generation
GEMINI_CHAT_MODEL=gemini-2.5-flash
# Model used for embeddings (used for both ingestion and query)
GEMINI_EMBED_MODEL=text-embedding-004

# --- Optional: switch generation to Claude later (paid) ---
# If ANTHROPIC_API_KEY is set, LLM_PROVIDER=claude routes generation
# (not embeddings) through Claude instead of Gemini.
LLM_PROVIDER=gemini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Pinecone (free tier: 1 project, serverless index) ---
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX=complianceagent
# Must match the embedding model's output dimensions (text-embedding-004 = 768)
PINECONE_DIMENSION=768

# --- Supabase (free tier project) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
